{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Nominal",
  "id": "nominal-nominalds-datasource",
  "metrics": true,
  "logs": true,
  "alerting": true,
  "backend": true,
  "executable": "gpx_nominal_ds",
  "info": {
    "description": "Nominal datasource plugin for Grafana - connect to Nominal's time-series platform for monitoring and visualization",
    "author": {
      "name": "Nominal inc"
    },
    "keywords": [
      "datasource",
      "nominal",
      "time-series",
      "monitoring"
    ],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "documentation",
        "url": "https://docs.nominal.io/"
      },
      {
        "name": "repository",
        "url": "https://github.com/nominal-io/grafana-plugin-public"
      },
      {
        "name": "license",
        "url": "https://github.com/nominal-io/grafana-plugin-public/blob/main/LICENSE"
      }
    ],
    "screenshots": [
      {
        "name": "Dashboard overview",
        "path": "img/dashboard.png"
      },
      {
        "name": "Data source configuration",
        "path": "img/datasource-config.png"
      },
      {
        "name": "Query editor",
        "path": "img/query-editor.png"
      },
      {
        "name": "Multiple aggregations",
        "path": "img/numeric-multi-aggregation.png"
      },
      {
        "name": "Banded series",
        "path": "img/numeric-banded.png"
      },
      {
        "name": "Numeric table",
        "path": "img/numeric-table.png"
      },
      {
        "name": "State timeline",
        "path": "img/string-state-timeline.png"
      },
      {
        "name": "Log channels",
        "path": "img/log-channels.png"
      },
      {
        "name": "Template variables",
        "path": "img/template-variables.png"
      }
    ],
    "version": "0.11.3",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=12.1.0",
    "plugins": []
  },
  "routes": [
    {
      "path": "test",
      "method": "GET",
      "reqRole": "Editor"
    },
    {
      "path": "connection-test",
      "method": "GET",
      "reqRole": "Editor"
    },
    {
      "path": "nominal/*",
      "method": "*",
      "reqRole": "Editor"
    }
  ]
}
